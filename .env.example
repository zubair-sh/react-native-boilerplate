# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the backend REST API.
# Expo requires the EXPO_PUBLIC_ prefix for values accessible in JS bundle.
EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# ─── App ──────────────────────────────────────────────────────────────────────
# App environment — used to conditionally enable debug tooling.
# Values: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# ─── Mocking ──────────────────────────────────────────────────────────────────
# Set to 'true' to use hardcoded mock data instead of hitting the real API.
# Flip to 'false' (or remove) once your backend is ready.
EXPO_PUBLIC_USE_MOCK=true
